#!/usr/bin/env bash
# BOB CLI — Build On BNB
# Usage: ./bob scout | push | oracle | database | deploy | swarm | status

cmd="${1:-help}"

case "$cmd" in
  scout)    npx tsx src/scout-fast.ts "${@:2}" ;;
  push)     npx tsx src/pusher.ts "${@:2}" ;;
  greet)    npx tsx src/pusher.ts -- --greet ;;
  database) npx tsx src/database.ts ;;
  oracle)   npx tsx src/oracle.ts ;;
  deploy)   npx tsx src/build-snapshot.ts && npx vercel --prod --yes ;;
  snapshot) npx tsx src/build-snapshot.ts ;;
  update)   npx tsx src/update-agents.ts ;;
  quick)
    echo ""
    echo "  ╔═══════════════════════════════════════════════════════╗"
    echo "  ║   BOB QUICK — Daily Agent Run                         ║"
    echo "  ║   Push + Database + Oracle + Deploy                   ║"
    echo "  ╚═══════════════════════════════════════════════════════╝"
    echo ""
    npx tsx src/oracle.ts &
    echo "  [1/3] 💬 PUSHER — Checking new agents + contacting..."
    echo "  ─────────────────────────────────────────────"
    npx tsx src/pusher.ts
    echo ""
    echo "  [2/3] 📊 DATABASE — Analyzing & Sorting..."
    echo "  ─────────────────────────────────────────────"
    npx tsx src/database.ts
    echo ""
    echo "  [3/3] 🚀 DEPLOY — Snapshot + Vercel..."
    echo "  ─────────────────────────────────────────────"
    npx tsx src/build-snapshot.ts && npx vercel --prod --yes
    echo ""
    echo "  ╔═══════════════════════════════════════════════════════╗"
    echo "  ║   QUICK COMPLETE — Oracle ran parallel                ║"
    echo "  ║   New agents checked, data sorted, deployed           ║"
    echo "  ╚═══════════════════════════════════════════════════════╝"
    echo ""
    ;;
  swarm)
    echo ""
    echo "  ╔═══════════════════════════════════════════════════════╗"
    echo "  ║   BOB SWARM — All 4 Agents Running                   ║"
    echo "  ║   Build On BNB                                       ║"
    echo "  ╚═══════════════════════════════════════════════════════╝"
    echo ""
    echo "  [1/4] 🔍 SCOUT — Scanning BSC Registry..."
    echo "  ─────────────────────────────────────────────"
    npx tsx src/scout-fast.ts
    echo ""
    echo "  [2/4] 📊 DATABASE — Analyzing & Sorting..."
    echo "  ─────────────────────────────────────────────"
    npx tsx src/database.ts
    echo ""
    echo "  [3/4] 💬 PUSHER — Contacting A2A Agents..."
    echo "  ─────────────────────────────────────────────"
    npx tsx src/pusher.ts
    echo ""
    echo "  [4/4] 🔮 ORACLE — System Check & Treasury..."
    echo "  ─────────────────────────────────────────────"
    npx tsx src/oracle.ts
    echo ""
    echo "  [DEPLOY] Building snapshot + deploying to Vercel..."
    echo "  ─────────────────────────────────────────────"
    npx tsx src/build-snapshot.ts && npx vercel --prod --yes
    echo ""
    echo "  ╔═══════════════════════════════════════════════════════╗"
    echo "  ║   SWARM COMPLETE — All agents finished               ║"
    echo "  ║   Data scanned, sorted, pushed, monitored & deployed ║"
    echo "  ╚═══════════════════════════════════════════════════════╝"
    echo ""
    ;;
  status)   echo ""; curl -s https://project-gkws4.vercel.app/health | npx tsx -e "process.stdin.on('data',d=>{const h=JSON.parse(d);console.log('  BOB '+h.version+' — '+h.status)})" ; echo "" ;;
  logs)     npx vercel logs https://project-gkws4.vercel.app --follow ;;
  chat)
    msg="${*:2}"
    if [ -z "$msg" ]; then msg="gm"; fi
    echo ""
    echo "  → Sending to BOB: \"$msg\""
    echo ""
    curl -s -X POST https://project-gkws4.vercel.app/ \
      -H "Content-Type: application/json" \
      -d "{\"jsonrpc\":\"2.0\",\"method\":\"message/send\",\"id\":\"cli\",\"params\":{\"message\":{\"role\":\"user\",\"parts\":[{\"text\":\"$msg\"}]}}}" \
      | npx tsx -e "process.stdin.on('data',d=>{const r=JSON.parse(d);console.log('  BOB: '+r.result.artifacts[0].parts[0].text)})"
    echo ""
    ;;
  *)
    echo ""
    echo "  ╔═══════════════════════════════════════════════════════════════╗"
    echo "  ║   BOB — Build On BNB | Agent Intelligence Service            ║"
    echo "  ╠═══════════════════════════════════════════════════════════════╣"
    echo "  ║                                                               ║"
    echo "  ║   MONITORING (ändert nichts, nur zum Schauen)                 ║"
    echo "  ║   ─────────────────────────────────────────────               ║"
    echo "  ║   [1] Status        Lebt BOB? Version + Health Check          ║"
    echo "  ║   [2] Oracle        System Health, Treasury, Endpoints        ║"
    echo "  ║   [3] Chat          Mit BOB reden (A2A Test)                  ║"
    echo "  ║   [4] Logs          Live sehen wer BOB anschreibt             ║"
    echo "  ║   [5] Dashboard     Im Browser öffnen                         ║"
    echo "  ║                                                               ║"
    echo "  ║   AKTIONEN (verändert Daten / kostet evtl. Gas)               ║"
    echo "  ║   ─────────────────────────────────────────────               ║"
    echo "  ║   [6] Scout         Registry scannen (~40 Min)                ║"
    echo "  ║                     → Findet neue/aktive Agents auf BSC       ║"
    echo "  ║                     → Wann: alle paar Tage                    ║"
    echo "  ║                                                               ║"
    echo "  ║   [7] Push          Neue Agents seit letztem Scan finden      ║"
    echo "  ║                     → Schneller als Scout, nur neue IDs       ║"
    echo "  ║                     → Wann: nach Scout oder zwischendurch     ║"
    echo "  ║                                                               ║"
    echo "  ║   [8] Greet         Neue Agents per A2A anschreiben           ║"
    echo "  ║                     → PUSHER schickt Gruss an echte Agents    ║"
    echo "  ║                     → Wann: nach Push, wenn neue gefunden     ║"
    echo "  ║                                                               ║"
    echo "  ║   [9] Deploy        Scan-Daten live pushen (Vercel)           ║"
    echo "  ║                     → Snapshot bauen + deployen               ║"
    echo "  ║                     → Wann: nach Scout/Push                   ║"
    echo "  ║                                                               ║"
    echo "  ║   [10] Update       Metadata on-chain updaten (kostet Gas!)   ║"
    echo "  ║                     → IPFS Upload + tokenURI auf BSC ändern   ║"
    echo "  ║                     → Wann: NUR wenn Services/Version ändert  ║"
    echo "  ║                     → Kostet: ~0.008 BNB für 4 Agents         ║"
    echo "  ║                                                               ║"
    echo "  ║   [11] Swarm        ALLE 4 AGENTS starten (Scout→DB→Push→Oracle)║"
    echo "  ║                     → Full Scan + Analyse + Outreach + Deploy ║"
    echo "  ║                     → Dauert: ~45 Min (Scout ist langsamster) ║"
    echo "  ║                                                               ║"
    echo "  ║   [0] Exit                                                    ║"
    echo "  ║                                                               ║"
    echo "  ╚═══════════════════════════════════════════════════════════════╝"
    echo ""
    read -p "  Auswahl [0-10]: " choice
    case "$choice" in
      1)  bash "$0" status ;;
      2)  bash "$0" oracle ;;
      3)  read -p "  Nachricht an BOB: " msg; bash "$0" chat "$msg" ;;
      4)  bash "$0" logs ;;
      5)  echo "  Opening dashboard..."; start "https://project-gkws4.vercel.app" 2>/dev/null || xdg-open "https://project-gkws4.vercel.app" 2>/dev/null || open "https://project-gkws4.vercel.app" 2>/dev/null || echo "  → https://project-gkws4.vercel.app" ;;
      6)  echo ""; echo "  Starting SCOUT scan..."; bash "$0" scout ;;
      7)  echo ""; echo "  Starting PUSHER..."; bash "$0" push ;;
      8)  echo ""; echo "  Starting PUSHER with greet..."; bash "$0" greet ;;
      9)  echo ""; echo "  Building snapshot + deploying..."; bash "$0" deploy ;;
      10) echo ""; echo "  ⚠️  Dies kostet BNB Gas! Sicher? (j/n)"; read -p "  > " confirm; if [ "$confirm" = "j" ]; then bash "$0" update; else echo "  Abgebrochen."; fi ;;
      11) echo ""; echo "  Starting FULL SWARM..."; bash "$0" swarm ;;
      0)  echo "  Bye!"; exit 0 ;;
      *)  echo "  Ungültige Auswahl." ;;
    esac
    ;;
esac
